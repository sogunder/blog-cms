MONGODB_URI=mongodb://admin:admin_pass@127.0.0.1:27018/blog_db?authSource=admin
PORT=3000
JWT_SECRET=super-secret-key-change-me
JWT_EXPIRES=900
JWT_REFRESH_SECRET=super-refresh-secret-key-change-me
JWT_REFRESH_EXPIRES=604800
CORS_ORIGIN=http://localhost:5173

# MongoDB Docker Config
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin_pass
MONGO_DATABASE=blog_db
MONGO_PORT=27018
MONGO_EXPRESS_PORT=8082

# Opcional: crea un admin si la BD está vacía para ese email
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456
SEED_ADMIN_NAME=Admin

# Datos de prueba (manual): desde raíz del repo o apps/api, con Mongo arriba
# pnpm seed:users  → admin@admin.cl + user@user.cl, contraseña 123456
# pnpm seed:demo   → lo mismo + categorías, tags, posts, comentarios (idempotente)
